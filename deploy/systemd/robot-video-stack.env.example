# Copy to /etc/default/robot-video-stack and adjust for the robot.
HOSTCOMPUTER_DIR=/home/rera/hostcomputer
VIDEO_SOURCES_CONFIG=/home/rera/hostcomputer/ros1_bridge/video_sources.local.yaml

# The advertised RTSP host is configured in video_sources.local.yaml as rtsp.public_host.
# Use RTSP_PUBLIC_HOST only as a temporary override.
# RTSP_PUBLIC_HOST=192.168.1.83
# RTSP_PUBLISH_HOST=127.0.0.1
RTSP_PORT=8554

START_MEDIAMTX=true
MEDIAMTX_BIN=mediamtx
# MEDIAMTX_EXTRA_ARGS=--config /etc/mediamtx/mediamtx.yml

VIDEO_MANAGER_HOST=127.0.0.1
VIDEO_MANAGER_PORT=18081
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=9090
DEBUG_HOST=0.0.0.0
DEBUG_PORT=18080

LOG_DIR=/tmp/rtsp_logs
PID_DIR=/tmp/robot_video_stack

# Optional: source ROS workspace setup before running roslaunch.
# ROS_SETUP=/home/rera/robot24_ws/devel/setup.bash

# Optional: pass extra launch/node arguments.
# VIDEO_MANAGER_EXTRA_ARGS=--dry-run
# BRIDGE_EXTRA_ARGS=
